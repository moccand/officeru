# ─────────────────────────────────────────────────────────────
# Copier ce fichier en .env et renseigner chaque variable.
# Ne jamais committer .env dans le dépôt git.
# ─────────────────────────────────────────────────────────────

# Environnement : development | staging | production
DJANGO_ENV=development

# Activer le mode debug (True en dev, False en prod)
DJANGO_DEBUG=False

# Clé secrète Django — générer avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=remplacer-par-une-vraie-cle-secrete

# Hôtes autorisés (séparés par des virgules)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Origines de confiance pour CSRF — requis derrière un reverse proxy (nginx, Traefik…)
# Exemple : https://monapp.example.com,https://www.monapp.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# ── Base de données ───────────────────────────────────────────
# SQLite (développement local)
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (staging / production)
DATABASE_URL=postgres://utilisateur:motdepasse@localhost:5432/nom_de_la_base

# Exemples d'URL avancées :
#   Avec SSL requis  : postgres://user:pass@host:5432/dbname?sslmode=require
#   Via socket Unix  : postgres:///dbname?host=/var/run/postgresql
#   Avec pool PgBouncer : postgres://user:pass@pgbouncer:6432/dbname

# ── Logs ─────────────────────────────────────────────────────
# Répertoire des fichiers de log (relatif au dossier ru/ ou chemin absolu)
DJANGO_LOG_DIR=logs

# Niveaux de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# application.log contient les logs applicatifs (y compris les erreurs)
DJANGO_LOG_LEVEL_APPLICATION=INFO
# acces.log contient les logs d'accès HTTP
DJANGO_LOG_LEVEL_ACCESS=DEBUG
# erreur.log contient uniquement les erreurs
DJANGO_LOG_LEVEL_ERROR=ERROR
